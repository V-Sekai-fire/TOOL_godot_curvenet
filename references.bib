% =================================================================
% Mixed-precision iterative refinement — the GPU CG path in todos/08
% runs the inner solve in fp32 (the only realistic precision on
% Adreno / RDNA-2 mobile compute) and recovers fp64-quality accuracy
% via a single fp64 residual + correction step on the CPU. These two
% papers are the canonical references for the technique; Carson &
% Higham 2018 generalises to three precisions (fp16/fp32/fp64) which
% becomes interesting once we move to fused tensor-core shaders.
% =================================================================

@article{Buttari2008MixedPrecision,
  author  = {Buttari, Alfredo and Dongarra, Jack and Langou, Julie and
             Langou, Julien and Luszczek, Piotr and Kurzak, Jakub},
  title   = {Mixed Precision Iterative Refinement Techniques for the
             Solution of Dense Linear Systems},
  journal = {The International Journal of High Performance Computing
             Applications},
  volume  = {21},
  number  = {4},
  year    = {2008},
  pages   = {457--466},
  doi     = {10.1177/1094342007084026}
}

@article{Carson2018IterativeRefinement,
  author  = {Carson, Erin and Higham, Nicholas J.},
  title   = {Accelerating the Solution of Linear Systems by Iterative
             Refinement in Three Precisions},
  journal = {SIAM Journal on Scientific Computing},
  volume  = {40},
  number  = {2},
  year    = {2018},
  pages   = {A817--A847},
  doi     = {10.1137/17M1140819}
}

% Canonical reference for fp accuracy + stability analysis. Covers
% the per-iter rounding-error growth in CG that explains why fp32
% storage of x stagnates above the fp32 precision floor when the
% iter count grows past ~1k. Specifically: §17 (CG and Lanczos)
% bounds the recoverable residual at O(eps · κ · ‖A‖ · ‖x‖), which
% for κ = 4e8 and fp32 (eps ≈ 1.2e-7) gives a floor around 0.05 —
% matching the 0.073 stagnation we measured on Mire 5k GPU CG.
@book{Higham2002Accuracy,
  author    = {Higham, Nicholas J.},
  title     = {Accuracy and Stability of Numerical Algorithms},
  edition   = {2nd},
  publisher = {SIAM},
  year      = {2002},
  isbn      = {0-89871-521-0},
  doi       = {10.1137/1.9780898718027}
}

% Modern survey of mixed-precision Krylov methods on GPUs —
% benchmarks the iterative-refinement variants on real
% architectures and quantifies the fp32 + fp64 hybrid speedups.
% Cited because it informs the choice of "GPU fp32 inner +
% CPU fp64 residual" over native GPU fp64 on Steam Deck/Quest 3.
@article{Anzt2019MixedPrecisionGPU,
  author  = {Anzt, Hartwig and Dongarra, Jack and Flegar, Goran and
             Higham, Nicholas J. and Quintana-Ort{\'\i}, Enrique S.},
  title   = {Adaptive Precision in Block-{Jacobi} Preconditioning for
             Iterative Sparse Linear System Solvers},
  journal = {Concurrency and Computation: Practice and Experience},
  volume  = {31},
  number  = {6},
  year    = {2019},
  pages   = {e4460},
  doi     = {10.1002/cpe.4460}
}

% Double-float (df32) arithmetic — represent each value as a pair of
% fp32 carries to recover ~48 bits of mantissa without paying for native
% fp64. Useful as a fallback if we ever can't afford the CPU residual
% roundtrip on Quest 3, but the inner kernels become 3-8x slower per
% op + 2x memory bandwidth, so iterative refinement (Buttari/Carson) is
% the cheaper default.
@inproceedings{DaGraca2006FloatFloat,
  author    = {Da Gra\c{c}a, Guillaume and Defour, David},
  title     = {Implementation of Float-Float Operators on Graphics
               Hardware},
  booktitle = {Real Numbers and Computers (RNC 7)},
  year      = {2006},
  pages     = {23--32}
}

