+        _nodes[_nodes[n].next].prev = _nodes[n].prev;
+      }
+
+      if(_nodes[n].prev != -1) {
+        _nodes[_nodes[n].prev].next = _nodes[n].next;
+      } else {
+        first_node = _nodes[n].next;
+      }
+
+      _nodes[n].next = first_free_node;
+      first_free_node = n;
+      _nodes[n].prev = -2;
+    }
+
+    void erase(const Edge& edge) {
