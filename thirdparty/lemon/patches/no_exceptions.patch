+        n = first_free_node;
+        first_free_node = _nodes[n].next;
+      }
+
+      _nodes[n].next = first_node;
+      if (first_node != -1) _nodes[first_node].prev = n;
+      first_node = n;
+      _nodes[n].prev = -1;
+
+      _nodes[n].first_out = -1;
+
+      return Node(n);
+    }
+
+    Edge addEdge(Node u, Node v) {
+      int n;
+
+      if (first_free_arc == -1) {
+        n = _arcs.size();
+        _arcs.push_back(ArcT());
+        _arcs.push_back(ArcT());
+      } else {
+        n = first_free_arc;
+        first_free_arc = _arcs[n].next_out;
+      }
