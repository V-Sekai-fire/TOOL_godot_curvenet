# Godot 4+ specific ignores
.godot/

# Ignore library files but not the gdextension file
demo/bin/*
!demo/bin/android
demo/bin/android/*
!demo/bin/android/.gitkeep
!demo/bin/linux
demo/bin/linux/*
!demo/bin/linux/.gitkeep
!demo/bin/macos
demo/bin/macos/*
!demo/bin/macos/.gitkeep
!demo/bin/windows
demo/bin/windows/*
!demo/bin/windows/.gitkeep
!demo/bin/*.gdextension
.sconsign*.dblite

# Ignore custom.py
custom.py

# Ignore generated compile_commands.json
compile_commands.json

# Binaries
*.o
*.os
*.so
*.obj
!demo/**/*.obj
*.bc
*.pyc
*.dblite
*.pdb
*.lib
*.config
*.creator
*.creator.user
*.files
*.includes
*.idb
*.exp
*.d

# Other stuff
*.log

# VSCode
.vscode/*
!.vscode/extensions.json
.DS_Store

bin/*
!bin/android
bin/android/*
!bin/android/.gitkeep
!bin/linux
bin/linux/*
!bin/linux/.gitkeep
!bin/macos
bin/macos/*
!bin/macos/.gitkeep
!bin/windows
bin/windows/*
!bin/windows/.gitkeep
!bin/*.gdextension

# Compiled test binaries and macOS debug symbol bundles
tests/bin/*
!tests/bin/.gitkeep
*.dSYM/

# Compiled shaders — produced by glslangValidator at test/build time.
# The .comp source under src/curvenet/shaders/ is tracked; the .spv
# output is regenerated and stays out of the tree. (Godot will compile
# and cache its own SPIR-V at runtime when these shaders move into
# the RenderingDevice path; that cache lives under .godot/.)
*.spv

src/gen/
.obsidian/

# Character mesh assets — externally sourced (V-Sekai-fire/mesh-mille-
# mire-feuille), too large to track in-tree. The bench reads pre-baked
# vertex data from tests/mire_body_data.h instead, so the .blend / .glb
# only need to be present locally when re-baking.
demo/character/*.blend
demo/character/*.glb

# 6.4 MB header from `Body` subdivided 2x for the 70k-vert
# benchmark. Regenerated via `make -C tests bench_70k_data` (or by
# hand via Blender MCP). Doesn't belong in git.
tests/mire_body_70k_data.h
