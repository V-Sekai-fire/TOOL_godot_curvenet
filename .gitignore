# Godot 4+ specific ignores
.godot/

# Ignore library files but not the gdextension file
demo/bin/*
!demo/bin/android
demo/bin/android/*
!demo/bin/android/.gitkeep
!demo/bin/linux
demo/bin/linux/*
!demo/bin/linux/.gitkeep
!demo/bin/macos
demo/bin/macos/*
!demo/bin/macos/.gitkeep
!demo/bin/windows
demo/bin/windows/*
!demo/bin/windows/.gitkeep
!demo/bin/*.gdextension
.sconsign*.dblite

# Ignore custom.py
custom.py

# Ignore generated compile_commands.json
compile_commands.json

# Binaries
*.o
*.os
*.so
*.obj
!demo/**/*.obj
*.bc
*.pyc
*.dblite
*.pdb
*.lib
*.config
*.creator
*.creator.user
*.files
*.includes
*.idb
*.exp
*.d

# Other stuff
*.log

# VSCode
.vscode/*
!.vscode/extensions.json
.DS_Store

bin/*
!bin/android
bin/android/*
!bin/android/.gitkeep
!bin/linux
bin/linux/*
!bin/linux/.gitkeep
!bin/macos
bin/macos/*
!bin/macos/.gitkeep
!bin/windows
bin/windows/*
!bin/windows/.gitkeep
!bin/*.gdextension

# Compiled test binaries and macOS debug symbol bundles
tests/bin/*
!tests/bin/.gitkeep
*.dSYM/

src/gen/
